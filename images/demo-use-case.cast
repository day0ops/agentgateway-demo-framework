[0.180, "o", "\u001b[34m\u001b[34mℹ\u001b[39m\u001b[34m\u001b[39m Deploying use case: openai-provider\r\n"]
[0.001, "o", "\r\n\u001b[36m\u001b[1m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[22m\u001b[39m\r\n"]
[0.000, "o", "\u001b[36m\u001b[1m  Use case: openai-provider\u001b[22m\u001b[39m\r\n"]
[0.000, "o", "\u001b[36m\u001b[1m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[22m\u001b[39m\r\n\r\n"]
[0.001, "o", "\u001b[37mThe minimal baseline: a single OpenAI (gpt-4o-mini) provider behind agentgateway.\u001b[39m\r\n\u001b[37m\u001b[39m\r\n\u001b[37m• providers feature with default settings at /openai\u001b[39m\r\n\u001b[37m• No extra policies, auth, or routing logic applied\u001b[39m\r\n\u001b[37m• Verifies end-to-end LLM request routing is functional\u001b[39m\r\n\u001b[37m\u001b[39m\r\n\r\n\u001b[2m  Steps:\u001b[22m\r\n"]
[0.000, "o", "\u001b[2m    1. Add provider  [providers]\u001b[22m\r\n\r\n"]
[0.036, "o", "\u001b[2m  Data flow:\u001b[22m\r\n\u001b[2m┌────────┐     ┌──────────────┐     ┌────────┐\u001b[22m\r\n\u001b[2m│        │     │              │     │        │\u001b[22m\r\n\u001b[2m│ Client ├────►│ AgentGateway ├────►│ OpenAI │\u001b[22m\r\n\u001b[2m│        │     │              │     │        │\u001b[22m\r\n\u001b[2m└────────┘     └──────────────┘     └────────┘\u001b[22m\r\n\r\n"]
[0.000, "o", "\u001b[2m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[22m\r\n\u001b[33m👉 Press SPACE to continue...\u001b[39m\r\n"]
[1.761, "o", "\r\n"]
[0.000, "o", "\u001b[33m\u001b[1m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[22m\u001b[39m\r\n"]
[0.000, "o", "\u001b[33m\u001b[1m  Step 1 of 1: Add provider\u001b[22m\u001b[39m\r\n"]
[0.000, "o", "\u001b[33m\u001b[1m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[22m\u001b[39m\r\n\r\n"]
