[0.000, "o", "\u001b[32m?\u001b[39m \u001b[1mSelect from \u001b[36mrouting\u001b[39m:\u001b[22m\u001b[0m \u001b[0m\r\n\u001b[36m❯ query param routing\u001b[39m \r\n  \u001b[2m──────────────\u001b[22m\r\n  \u001b[2m← Back\u001b[22m \r\n  anthropic model on vertex ai provider \r\n  bedrock provider with apikey \r\n  bedrock provider with credentials \r\n  body routing combined \r\n  body routing embeddings \r\n  body routing regex \r\n  body routing with failover \r\n\u001b[2m(Move up and down to reveal more choices)\u001b[22m\u001b[?25l\u001b[41D\u001b[41C"]
